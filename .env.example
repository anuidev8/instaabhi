# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ELEVENLABS_VOICE_ID: Legacy voice ID kept for backward compatibility.
# Current default reels flow keeps ElevenLabs disabled (scene-provider video + Fal concat only).
ELEVENLABS_VOICE_ID="MY_ELEVENLABS_VOICE_ID"

# DEV ONLY (insecure): direct Fal client key in browser.
# For production, do NOT expose this; use server proxy + FAL_KEY.
VITE_FAL_KEY="MY_FAL_KEY"

# DEV ONLY (insecure): direct ElevenLabs credentials/voice in browser.
# Used by App Marketing Video Generation tab (voiceover) and optional strict reels audio.
VITE_ELEVENLABS_API_KEY="MY_ELEVENLABS_API_KEY"
VITE_ELEVENLABS_VOICE_ID="MY_ELEVENLABS_VOICE_ID"
VITE_ELEVENLABS_MODEL_ID="eleven_multilingual_v2"

# Optional strict reels pipeline (off by default).
# When true, the app runs transition-aware assembly + optional audio/subtitle passes.
VITE_REELS_STRICT_SPEC_MODE="false"
# Optional in strict mode: synthesize ElevenLabs voiceover and layer it into final reel.
VITE_REELS_STRICT_ENABLE_ELEVENLABS_AUDIO="false"
# Optional in strict mode: add styled subtitle overlay pass (gold-ish branding).
VITE_REELS_STRICT_ENABLE_AUTO_SUBTITLE="false"
# Optional in strict mode: ambient bed URL layered under reel audio.
VITE_REEL_AMBIENT_AUDIO_URL=""
# Frontend-only reference mode: split source video directly using sourceStart/sourceEnd timestamps.
VITE_REELS_REFERENCE_CLIP_MODE="true"

# Optional Gemini model overrides (advanced):
# If unset, the app uses safe defaults with automatic fallback.
GEMINI_MODEL_DRAFT="gemini-3.1-pro-preview"
GEMINI_MODEL_REELS="gemini-3.1-pro-preview"
GEMINI_MODEL_POST="gemini-3.1-pro-preview"
GEMINI_VIDEO_MODEL="veo-3.1-generate-preview"
GEMINI_VIDEO_API_BASE="https://generativelanguage.googleapis.com/v1beta"

# Nano Banana model for carousel image generation (Generate with AI).
# Default: gemini-3.1-flash-image-preview (Nano Banana 2). Alternative: gemini-3-pro-image-preview (Nano Banana Pro).
GEMINI_IMAGE_MODEL="gemini-3.1-flash-image-preview"

# OpenAI API key (optional) for GPT Image 1.5 image generation.
# Required only if you select "OpenAI (GPT Image 1.5)" in the image model dropdown.
# GPT Image 1.5 is OpenAI's flagship model; DALL·E 3 is deprecated May 2026.
OPENAI_API_KEY=""
OPENAI_VIDEO_MODEL="sora-1"
OPENAI_VIDEO_ENDPOINT="https://api.openai.com/v1/videos"

# Meta / Instagram Graph API backend variables (optional for token-only mode).
# Keep these empty if you only want direct token connection via INSTAGRAM_USER_ACCESS_TOKEN
# or /auth/instagram/manual-connect.
META_APP_ID=""
META_APP_SECRET=""
META_REDIRECT_URI=""
META_GRAPH_VERSION="v19.0"
META_SCOPE="pages_show_list,instagram_basic,instagram_manage_insights,instagram_content_publish"
IG_SERVER_PORT="8787"
IG_CONNECTED_REDIRECT="http://localhost:3000"
DEV_USER_ID="dev-user"

# Optional local pre-connect token for dev startup (token-only mode supported).
INSTAGRAM_USER_ACCESS_TOKEN=""

# Frontend -> backend base URL for Instagram endpoints.
VITE_IG_API_BASE_URL="http://localhost:8787"
VITE_DEV_USER_ID="dev-user"

# Cloudinary server-side upload (used to convert local/base64 images into public URLs for Instagram Graph API).
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
